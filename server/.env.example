# AI 同声传译助手 — 环境变量模板
# 复制此文件为 .env 并填入实际值

HOST=0.0.0.0
PORT=8000

# Deepgram (流式 ASR)
DEEPGRAM_API_KEY=

# DeepSeek (翻译)
DEEPSEEK_API_KEY=

# OpenAI (备用翻译)
OPENAI_API_KEY=

# Azure Speech (备用 ASR)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# 修正引擎
CORRECTION_ENABLED=true
MAX_CORRECTION_CALLS=20

# RAG 知识库
RAG_ENABLED=true
RAG_DATA_DIR=server/data/chroma
